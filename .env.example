# ═══════════════════════════════════════════════════════
#  RESEND — Email delivery for booking + contact forms
# ═══════════════════════════════════════════════════════

# 1. Create account at https://resend.com
# 2. Add these variables at Vercel → Project → Settings → Environment Variables
# 3. (Also copy them into a local .env file for `vercel dev`)

# Your Resend API key (starts with re_...)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address — MUST be a verified domain on Resend.
# For initial testing you can use: "National Friend <onboarding@resend.dev>"
# Once you verify national-friend.gr on Resend, switch to e.g.:
#   "National Friend <noreply@national-friend.gr>"
FROM_EMAIL=National Friend <onboarding@resend.dev>

# Recipient — where booking + contact submissions should arrive
TO_EMAIL=info@national-friend.gr
